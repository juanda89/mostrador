# =========================================================
# Mostrador — Variables de entorno
# Copia este archivo a .env y rellena con tus claves reales.
# El .env NUNCA se commitea (está en .gitignore).
#
# En producción, las claves se cargan vía:
#   supabase secrets set --env-file .env
# =========================================================

# --- Anthropic (Claude Opus 4.7, Sonnet 4.6, Haiku 4.5) ---
# Crear en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (Whisper para transcripción de audio) ---
# Crear en: https://platform.openai.com
OPENAI_API_KEY=sk-...

# --- Google Gemini (extracción de imágenes: facturas, menús) ---
# Crear en: https://aistudio.google.com
GEMINI_API_KEY=...

# --- Supabase ---
# Local: las pobla `supabase start` (anon/service role aparecen en stdout).
# Producción: tomar del Dashboard → Project Settings → API.
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...        # ¡Solo backend! Bypassea RLS.

# --- Supabase CLI auth (necesarias para db push y functions deploy) ---
# SUPABASE_ACCESS_TOKEN: Personal Access Token de tu cuenta.
# Crear en: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=...
# SUPABASE_DB_PASSWORD: contraseña de la DB del proyecto.
# Ver/resetear en: Dashboard → Project Settings → Database.
SUPABASE_DB_PASSWORD=...

# --- Kapso (provisión del número WhatsApp Business) ---
# Crear en: https://kapso.ai
# API base URL: https://api.kapso.ai/meta/whatsapp/v24.0
KAPSO_API_KEY=...                    # X-API-Key del proyecto en Kapso
KAPSO_PHONE_NUMBER_ID=...            # WhatsApp Business Phone Number ID (va en el path al enviar)
KAPSO_WEBHOOK_SECRET=...             # HMAC-SHA256 secret: lo defines tú y lo pegas también en Kapso Dashboard.
                                     # Generar: openssl rand -hex 32

# --- Cron (shared secret entre pg_cron y la edge function) ---
# Generar con: openssl rand -hex 32
CRON_SECRET=...

# --- Observabilidad (opcional, dejar vacío si no se usan) ---
# Helicone proxea las llamadas LLM para trazabilidad sin código extra.
# Crear en: https://helicone.ai
HELICONE_API_KEY=

# Sentry para tracking de errores. DSN del proyecto Deno.
# Crear en: https://sentry.io
SENTRY_DSN=

# --- App ---
LOG_LEVEL=info                       # debug | info | warn | error
PUBLIC_BASE_URL=https://<PROJECT_REF>.supabase.co/functions/v1
