{
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.ns", "esnext"]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "singleQuote": false,
    "semiColons": true
  },
  "tasks": {
    "test": "deno test --allow-all tests/unit/",
    "test:integration": "deno test --allow-all tests/integration/",
    "serve:local": "supabase functions serve --env-file .env --no-verify-jwt",
    "deploy": "supabase functions deploy whatsapp-webhook --no-verify-jwt && supabase functions deploy cron-tick --no-verify-jwt",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --local > supabase/functions/_shared/types/db.ts",
    "secrets:push": "supabase secrets set --env-file .env"
  },
  "imports": {
    "@/": "./supabase/functions/_shared/",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@^2.45.0",
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.30.0",
    "openai": "npm:openai@^4.67.0",
    "@google/generative-ai": "npm:@google/generative-ai@^0.21.0",
    "zod": "npm:zod@^3.23.0"
  }
}
